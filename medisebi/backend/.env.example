# ── MediSebi Backend Environment Variables ──────────────
# Copy this file to .env and set the values for your deployment.

# ── Application ──────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false

# ── Security (MUST change in production!) ────────────────
SECRET_KEY=your-super-secret-jwt-key-here-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ─────────────────────────────────────────────
# SQLite (for development):
DATABASE_URL=sqlite:///./medisebi.db
# PostgreSQL (for production):
# DATABASE_URL=postgresql://user:password@localhost:5432/medisebi

# ── CORS (comma-separated list of allowed origins) ───────
# Set this to your frontend domain when deploying separately
CORS_ORIGINS=https://your-frontend-domain.com,http://localhost:5173

# ── OpenWeather API (optional) ──────────────────────────
OPENWEATHER_API_KEY=

# ── Server ───────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
